# Required. Postgres connection string (e.g. Neon).
DATABASE_URL=postgres://user:password@localhost:5432/income_academy_crm

# Required. Minimum 32 chars. Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-32-plus-char-random-string-xxxxxxxxxxxxxxxxx

# Set to "production" on Render/Vercel; enables HTTPS enforcement + strict CORS.
NODE_ENV=development

PORT=4000

# Dev-only. In production, CORS is hardcoded to https://dashboard.incomeacademy.biz.
CLIENT_ORIGIN=http://localhost:5173

# Optional. Extra allowed CORS origin, e.g. https://xxx.vercel.app during initial deploy.
# Leave unset in steady state (production uses incomeacademy.biz).
EXTRA_ORIGIN=

# Stripe (Phase 6). Secret key from Stripe Dashboard → Developers → API keys.
# Use sk_test_... for Sandbox, sk_live_... for real payments.
# NEVER commit. Render env var only.
STRIPE_SECRET_KEY=

# Webhook signing secret from Stripe Dashboard → Developers → Webhooks
# → click the endpoint → "Signing secret".
# Use different secret for test vs live endpoints.
STRIPE_WEBHOOK_SECRET=

# CRM user_id that owns leads created from Stripe webhooks.
# Set to your admin user id (see: SELECT id, email FROM users).
# Defaults to 1 if unset.
OWNER_USER_ID=1

# MailerLite (Phase 7). API key + buyer group ID for welcome automation.
MAILERLITE_API_KEY=
MAILERLITE_BUYER_GROUP_ID=

# GoHighLevel (Phase 8). Private Integration Token + sub-account Location ID.
# Token is scoped to one Location. GHL workflow (configured in GHL UI) handles
# course enrollment + portal-access email based on the "stripe-buyer" tag.
GHL_API_KEY=
GHL_LOCATION_ID=

# Lead Intake (Phase 9). Shared secret for the public lead-intake endpoint.
# External callers (Meta Lead Ads, MailerLite forms, Zapier) send this in
# an X-Intake-Token header. Generate with: openssl rand -hex 32
INTAKE_TOKEN=

# MailerLite integration (Phase 7).
# API key from MailerLite → Integrations → Developer API.
# Used to add buyers to a MailerLite group that triggers the welcome
# email automation. Non-fatal if missing; webhook continues without it.
MAILERLITE_API_KEY=

# Numeric MailerLite group ID that buyers are added to. Buyers added to
# this group trigger MailerLite's welcome automation.
# Find this in MailerLite → Subscribers → Groups → click group → URL contains /groups/<id>.
MAILERLITE_BUYER_GROUP_ID=
